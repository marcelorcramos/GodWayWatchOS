            "categoria": "Ansiedade",
            "livro": "Salmos",
            "capitulo": 46,
            "versiculo": 1
        },
        {
            "id": "7",
            "texto": "Espera no Senhor, anima-te, e ele fortalecerá o teu coração.",
            "referencia": "Salmos 27:14",
            "categoria": "Esperança",
            "livro": "Salmos",
            "capitulo": 27,
            "versiculo": 14
        },
        {
